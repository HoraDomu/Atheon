#!/bin/bash
# Pre-commit hook - Comprehensive validation including build testing

echo "=== COMMIT VALIDATION ==="

# Check commit message for conventional format
commit_msg=$(git log -1 --pretty=%s)
if [[ ! "$commit_msg" =~ ^(feat|fix|docs|test|refactor|chore|style|infra|patterns): ]]; then
    echo "WARNING: Commit doesn't follow conventional format: '$commit_msg'"
    echo "Consider using: feat:, fix:, docs:, test:, refactor:, chore:, style:"
fi

# Check for EXACT user attribution
author=$(git config user.name)
email=$(git config user.email)

if [ "$author" != "aliasfoxkde" ]; then
    echo "ERROR: Commit author is '$author' (must be EXACTLY 'aliasfoxkde')"
    echo "Run: git config user.name 'aliasfoxkde' && git config user.email 'aliasfox@users.noreply.github.com'"
    exit 1
fi

if [ "$email" != "aliasfox@users.noreply.github.com" ]; then
    echo "ERROR: Commit email is '$email' (must be 'aliasfox@users.noreply.github.com')"
    echo "Run: git config user.email 'aliasfox@users.noreply.github.com'"
    exit 1
fi

# Run Go build validation if Go files changed OR if this is a Go project
if git diff --cached --name-only | grep -E '\.go$' >/dev/null || [ -f "go.mod" ]; then
    echo "=== BUILD VALIDATION ==="

    # Check if go.mod exists and we're in a Go project
    if [ -f "go.mod" ]; then
        echo "Testing Go build..."
        BUILD_OUTPUT=$(go build -v ./... 2>&1)
        if echo "$BUILD_OUTPUT" | grep -E "error|warning" >/dev/null; then
            echo "ERROR: Build failed with errors or warnings"
            echo "$BUILD_OUTPUT"
            exit 1
        else
            echo "✓ Build successful"
        fi

        # Run go vet for static analysis
        echo "Running go vet..."
        VET_OUTPUT=$(go vet ./... 2>&1)
        if [ $? -ne 0 ]; then
            echo "ERROR: go vet found issues"
            echo "$VET_OUTPUT"
            exit 1
        else
            echo "✓ go vet passed"
        fi

        # Check formatting
        echo "Checking code formatting..."
        UNFORMATTED=$(gofmt -l . 2>/dev/null || true)
        if [ -n "$UNFORMATTED" ]; then
            echo "ERROR: Code is not properly formatted"
            echo "Files needing formatting:"
            echo "$UNFORMATTED"
            echo "Run: gofmt -s -w ."
            exit 1
        else
            echo "✓ Code properly formatted"
        fi

        # Run go test if tests exist
        if ls *_test.go 1>/dev/null 2>&1 || find . -name "*_test.go" -q | grep -q .; then
            echo "Running tests..."
            TEST_OUTPUT=$(go test ./... -race -timeout 30s 2>&1)
            if echo "$TEST_OUTPUT" | grep -E "FAIL|error" >/dev/null; then
                echo "WARNING: Some tests failed - consider fixing before commit"
                echo "$TEST_OUTPUT" | tail -10
            else
                echo "✓ Tests passed"
            fi
        fi
    fi
fi

# Rebuild patterns bundle if community patterns changed
if git diff --cached --name-only | grep -E 'community/.*\.yaml$' >/dev/null; then
    echo "=== PATTERN BUNDLE UPDATE ==="
    if [ -f "bundler/main.go" ]; then
        echo "Rebuilding patterns bundle..."
        if ! go run ./bundler; then
            echo "ERROR: Failed to rebuild patterns bundle"
            exit 1
        fi

        # Stage the updated bundle
        git add core/patterns.bundle
        echo "✓ Patterns bundle updated and staged"
    fi
fi

echo "=== VALIDATION SUMMARY ==="
echo "✓ Commit message: $commit_msg"
echo "✓ Author: $author <$email>"
echo "=== COMMIT VALIDATION PASSED ==="
